# =============================================================================
# Sentiment Analysis Chatbot - Environment Variables (template)
# =============================================================================
# Copy this file to ".env" and adjust the values for your deployment.
# Every variable is OPTIONAL: the application ships with sensible defaults
# defined in config/settings.py.
# =============================================================================

# -----------------------------------------------------------------------------
# Filesystem locations (absolute or relative to the project root)
# -----------------------------------------------------------------------------
DATA_DIR=data
MODELS_DIR=models
LOGS_DIR=logs

RAW_DATASET_FILENAME=Reddit_Data.csv
SENTIMENT_MODEL_FILENAME=sentiment_analysis.h5
TFIDF_VECTORIZER_FILENAME=tfidf_vectorizer.pkl
RESPONSES_FILENAME=responses.pkl

# -----------------------------------------------------------------------------
# Dataset schema
# -----------------------------------------------------------------------------
TEXT_COLUMN=text
LABEL_COLUMN=category

# -----------------------------------------------------------------------------
# Feature extraction
# -----------------------------------------------------------------------------
TFIDF_MAX_FEATURES=5000

# -----------------------------------------------------------------------------
# Training hyper-parameters
# -----------------------------------------------------------------------------
TEST_SIZE=0.2
RANDOM_STATE=42
DENSE_UNITS_LAYER_1=256
DENSE_UNITS_LAYER_2=128
DROPOUT_RATE=0.5
EPOCHS=30
BATCH_SIZE=32
TRAINING_VERBOSITY=1

# -----------------------------------------------------------------------------
# Streamlit UI
# -----------------------------------------------------------------------------
APP_TITLE=Sentiment Analysis Chatbot
APP_SUBTITLE=Chat with me and I'll predict the sentiment of your text!

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
